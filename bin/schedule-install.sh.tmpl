#!/bin/zsh
# Idempotent installer for the four launchd agents that fire restic-wrap.sh
# on a calendar schedule. Re-running this script after editing the schedules
# below (or after a `bin/configure.sh` re-render) reinstalls the agents.
#
# The plists are written by hand rather than generated via
# `resticprofile schedule` because macOS 26.5+ rejects several plist fields
# resticprofile emits by default (LowPriorityBackgroundIO, Nice,
# ProcessType, WorkingDirectory) under BTM's "Unknown Developer" parent,
# which disables the agents at spawn time. The minimal plist below avoids
# that trap.

set -euo pipefail

WRAPPER="$HOME/backups/bin/restic-wrap.sh"
CONFIG="$HOME/backups/config/profiles.toml"
LOG_DIR="$HOME/backups/logs"
PLIST_DIR="$HOME/Library/LaunchAgents"
LABEL_PREFIX="{{LABEL_PREFIX}}"
UID_NUM="$(/usr/bin/id -u)"

# command:cron-style schedule. Format: "H M [Weekday]" — Weekday is 0-6
# (Sunday=0), omitted means daily.
schedules=(
  "backup:2 30"
  "forget:3 0"
  "prune:4 0 0"
  "check:5 0 0"
)

mkdir -p "$LOG_DIR"

for entry in "${schedules[@]}"; do
  cmd="${entry%%:*}"
  spec="${entry#*:}"
  read -r hour minute weekday <<<"$spec"
  label="$LABEL_PREFIX.$cmd"
  plist="$PLIST_DIR/$label.plist"

  # Calendar interval body. Weekday is optional.
  if [[ -n "${weekday:-}" ]]; then
    interval="<dict><key>Weekday</key><integer>$weekday</integer><key>Hour</key><integer>$hour</integer><key>Minute</key><integer>$minute</integer></dict>"
  else
    interval="<dict><key>Hour</key><integer>$hour</integer><key>Minute</key><integer>$minute</integer></dict>"
  fi

  cat > "$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$label</string>
  <key>Program</key>
  <string>/bin/zsh</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>$WRAPPER</string>
    <string>--no-prio</string>
    <string>--no-ansi</string>
    <string>--config</string>
    <string>$CONFIG</string>
    <string>run-schedule</string>
    <string>${cmd}@default</string>
  </array>
  <key>StandardErrorPath</key>
  <string>$LOG_DIR/launchd-$cmd.err.log</string>
  <key>StandardOutPath</key>
  <string>$LOG_DIR/launchd-$cmd.out.log</string>
  <key>StartCalendarInterval</key>
  <array>$interval</array>
</dict>
</plist>
EOF

  /bin/launchctl bootout "gui/$UID_NUM/$label" 2>/dev/null || true
  /bin/launchctl bootstrap "gui/$UID_NUM" "$plist"
  echo "installed: $label"
done

echo
echo "Done. Verify with:"
echo "  launchctl list | grep $LABEL_PREFIX"
