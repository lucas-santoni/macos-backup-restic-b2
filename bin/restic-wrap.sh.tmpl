#!/bin/zsh
# Self-contained wrapper that loads restic credentials from macOS Keychain
# into the environment then exec's resticprofile with the given arguments.
#
# Usage:
#   ~/backups/bin/restic-wrap.sh -n default backup
#   ~/backups/bin/restic-wrap.sh -n default snapshots

set -e

# launchd's default PATH is /usr/bin:/bin:/usr/sbin:/sbin. Prepend Homebrew so
# resticprofile can find the `restic` binary it shells out to.
export PATH="/opt/homebrew/bin:$PATH"

# Fetch a keychain entry into a named variable. zsh's `set -e` does NOT
# abort the parent shell when a command inside $(...) exits non-zero, so
# a `security` failure would otherwise leave us silently carrying an empty
# value forward. We capture the output, then explicitly check both exit
# status and emptiness, and exit 11 on failure.
fetch_secret() {
  local var_name="$1" service="$2" out
  out="$(security find-generic-password -a {{USERNAME}} -s "$service" -w 2>&1)"
  if [[ $? -ne 0 || -z "$out" ]]; then
    echo "restic-wrap: keychain read failed for $service: $out" >&2
    exit 11
  fi
  export "$var_name=$out"
}

fetch_secret RESTIC_PASSWORD restic-repo-password
fetch_secret B2_ACCOUNT_ID   restic-b2-key-id
fetch_secret B2_ACCOUNT_KEY  restic-b2-app-key
export RESTIC_CACHE_DIR="$HOME/backups/cache"

# Inject --config so interactive use (e.g. `restic-wrap.sh snapshots`) doesn't
# require typing the absolute path. Scheduled launchd plists already pass
# --config, so the check is a pass-through there.
if [[ "$*" != *"--config"* ]]; then
  set -- --config "$HOME/backups/config/profiles.toml" "$@"
fi

exec /opt/homebrew/bin/resticprofile "$@"
