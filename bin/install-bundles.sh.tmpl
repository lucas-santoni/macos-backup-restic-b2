#!/bin/zsh
# Build the four "{{BUNDLE_NAME_PREFIX}} <Cmd>.app" bundles that launchd
# uses as the user-facing wrappers for the resticprofile schedules. Each
# bundle owns:
#
#   - Contents/MacOS/{{BUNDLE_NAME_PREFIX}} <Cmd>  → real Mach-O launcher
#                                           (from bin/launcher.c) that
#                                           execs /bin/zsh with our
#                                           restic-wrap.sh as argv[1].
#   - Contents/Resources/icon.icns       → 💾 emoji rasterized to .icns
#   - Contents/Info.plist                → CFBundleName
#                                           "{{BUNDLE_NAME_PREFIX}} <Cmd>",
#                                           CFBundleIconFile "icon",
#                                           LSUIElement + LSBackgroundOnly,
#                                           CFBundleIdentifier
#                                           {{BUNDLE_ID_PREFIX}}.<cmd>
#
# After construction, each bundle is ad-hoc signed with --identifier set to
# its bundle ID. This is essential for two reasons:
#   1. Login Items resolves CFBundleIconFile correctly only when the bundle
#      has a valid signature. Without one, NSWorkspace falls back to the
#      generic exec icon for the inner binary.
#   2. TCC binds Full Disk Access grants to a bundle's Designated
#      Requirement. An unsigned bundle has a malformed DR, so FDA grants
#      don't apply at runtime → per-folder popups fire on every launch.
#
# Idempotent: existing bundles are removed and rebuilt. Run this BEFORE
# schedule-install.sh on a fresh machine; safe to re-run anytime.
#
# IMPORTANT: re-running this script changes each bundle's cdhash, which
# invalidates any FDA grants you'd previously added in System Settings.
# After re-running, you must remove and re-add the four bundles in
# Privacy & Security → Full Disk Access.

set -euo pipefail
setopt nullglob

REPO="$HOME/Documents/backups"
SUPPORT="$HOME/Documents/backups/bundles"
TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"' EXIT

LAUNCHER_BIN="$TMP/launcher"
ICON_FILE="$TMP/icon.icns"

echo "[1/4] Compiling launcher binary (arm64)..."
# The launcher is built for Apple Silicon (arm64) by default. On Intel,
# change `-arch arm64` to `-arch x86_64`; for a universal build, pass both
# `-arch arm64 -arch x86_64`.
clang -O2 -arch arm64 -o "$LAUNCHER_BIN" "$REPO/bin/launcher.c"

echo "[2/4] Rendering 💾 emoji to .icns..."
"$REPO/bin/emoji-to-icns.sh" "💾" "$ICON_FILE" >/dev/null

echo "[3/4] (Re)building bundles..."
mkdir -p "$SUPPORT"
for cmd in backup forget prune check; do
  Cmd="$(echo "$cmd" | /usr/bin/awk '{print toupper(substr($0,1,1)) substr($0,2)}')"
  bundle="$SUPPORT/{{BUNDLE_NAME_PREFIX}} ${Cmd}.app"
  rm -rf "$bundle"
  mkdir -p "$bundle/Contents/MacOS" "$bundle/Contents/Resources"
  exe="$bundle/Contents/MacOS/{{BUNDLE_NAME_PREFIX}} ${Cmd}"
  cp "$LAUNCHER_BIN" "$exe"
  chmod +x "$exe"
  cp "$ICON_FILE" "$bundle/Contents/Resources/icon.icns"
  cat > "$bundle/Contents/Info.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleName</key>
  <string>{{BUNDLE_NAME_PREFIX}} ${Cmd}</string>
  <key>CFBundleDisplayName</key>
  <string>{{BUNDLE_NAME_PREFIX}} ${Cmd}</string>
  <key>CFBundleIdentifier</key>
  <string>{{BUNDLE_ID_PREFIX}}.${cmd}</string>
  <key>CFBundleExecutable</key>
  <string>{{BUNDLE_NAME_PREFIX}} ${Cmd}</string>
  <key>CFBundleIconFile</key>
  <string>icon</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleShortVersionString</key>
  <string>1.0</string>
  <key>CFBundleVersion</key>
  <string>1</string>
  <key>LSUIElement</key>
  <true/>
  <key>LSBackgroundOnly</key>
  <true/>
</dict>
</plist>
PLIST
  echo "  built {{BUNDLE_NAME_PREFIX}} ${Cmd}.app"
done

echo "[4/4] Ad-hoc signing each bundle with its bundle identifier..."
# `codesign --deep` signs the bundle and everything under it (including the
# inner Mach-O), producing a signed bundle whose Designated Requirement is
# tied to the per-bundle CDHash + Identifier we set here. With this, TCC
# can reliably bind FDA grants to the bundle and Login Items resolves
# CFBundleIconFile correctly.
for cmd in backup forget prune check; do
  Cmd="$(echo "$cmd" | /usr/bin/awk '{print toupper(substr($0,1,1)) substr($0,2)}')"
  bundle="$SUPPORT/{{BUNDLE_NAME_PREFIX}} ${Cmd}.app"
  codesign --force --deep --sign - --identifier "{{BUNDLE_ID_PREFIX}}.${cmd}" "$bundle"
  codesign --verify --verbose=2 "$bundle"
done

LSREG=/System/Library/Frameworks/CoreServices.framework/Versions/A/Frameworks/LaunchServices.framework/Versions/A/Support/lsregister
for cmd in backup forget prune check; do
  Cmd="$(echo "$cmd" | /usr/bin/awk '{print toupper(substr($0,1,1)) substr($0,2)}')"
  "$LSREG" -f "$SUPPORT/{{BUNDLE_NAME_PREFIX}} ${Cmd}.app"
done

echo
echo "Done. Bundles ready at:"
ls -d "$SUPPORT"/{{BUNDLE_NAME_PREFIX}}\ *.app
echo
echo "Next steps:"
echo "  1. System Settings → Privacy & Security → Full Disk Access"
echo "     Add (or re-add) all four {{BUNDLE_NAME_PREFIX}} <Cmd>.app bundles."
echo "     Re-running this script changes their cdhashes, so existing FDA"
echo "     grants from a previous run no longer apply."
echo "  2. bin/schedule-install.sh to (re)install the launchd agents."
