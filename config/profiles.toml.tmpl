version = "2"

[global]
default-command = "snapshots"
initialize = false
priority = "low"

# Lock notes (apply to backup/forget/prune/check below):
# - lock-wait covers resticprofile's profile lock.
# - retry-lock is forwarded to restic as --retry-lock and covers restic's
#   repository lock inside the B2 bucket.
# Both are needed because DarkWake-fragmented runs can let a previous job
# still hold one or the other when the next one fires. 4h gives the trailing
# job a wide window to release.

[profiles.default]
description = "Home directory backup to Backblaze B2"
initialize = false
repository = "{{B2_REPO}}"

  [profiles.default.backup]
  source = ["/Users/{{USERNAME}}"]
  exclude-file = "/Users/{{USERNAME}}/backups/config/excludes.txt"
  exclude-caches = true
  one-file-system = true
  tag = ["scheduled"]
  verbose = 1
  lock-wait = "4h"
  retry-lock = "4h"
  # NOTIFY:BEGIN
  run-after      = ["/Users/{{USERNAME}}/backups/bin/restic-notify.sh success"]
  run-after-fail = ["/Users/{{USERNAME}}/backups/bin/restic-notify.sh failure"]
  # NOTIFY:END
  # `schedule` must stay even though the actual scheduling is done by the
  # hand-rolled plist in bin/schedule-install.sh: resticprofile keys
  # `schedule-log` and run-after hook firing off the schedule's existence
  # under `run-schedule`. Without it, output goes to the launchd stdio file
  # and hooks don't fire. Should match the plist's StartCalendarInterval.
  schedule = "*-*-* 02:30:00"
  schedule-log = "/Users/{{USERNAME}}/backups/logs/backup.log"

  # Retention: 30 daily snapshots, then 1 per calendar month kept effectively forever.
  [profiles.default.forget]
  keep-daily = 30
  keep-weekly = 0
  keep-monthly = 9999
  keep-yearly = 0
  prune = false
  lock-wait = "4h"
  retry-lock = "4h"
  # NOTIFY:BEGIN
  run-after      = ["/Users/{{USERNAME}}/backups/bin/restic-notify.sh success"]
  run-after-fail = ["/Users/{{USERNAME}}/backups/bin/restic-notify.sh failure"]
  # NOTIFY:END
  schedule = "*-*-* 03:00:00"
  schedule-log = "/Users/{{USERNAME}}/backups/logs/forget.log"

  [profiles.default.prune]
  lock-wait = "4h"
  retry-lock = "4h"
  # NOTIFY:BEGIN
  run-after      = ["/Users/{{USERNAME}}/backups/bin/restic-notify.sh success"]
  run-after-fail = ["/Users/{{USERNAME}}/backups/bin/restic-notify.sh failure"]
  # NOTIFY:END
  schedule = "Sun *-*-* 04:00:00"
  schedule-log = "/Users/{{USERNAME}}/backups/logs/prune.log"

  [profiles.default.check]
  read-data-subset = "5%"
  lock-wait = "4h"
  retry-lock = "4h"
  # NOTIFY:BEGIN
  run-after      = ["/Users/{{USERNAME}}/backups/bin/restic-notify.sh success"]
  run-after-fail = ["/Users/{{USERNAME}}/backups/bin/restic-notify.sh failure"]
  # NOTIFY:END
  schedule = "Sun *-*-* 05:00:00"
  schedule-log = "/Users/{{USERNAME}}/backups/logs/check.log"
